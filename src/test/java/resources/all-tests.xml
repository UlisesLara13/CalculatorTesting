<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="CalculatorTestSuite" parallel="classes" thread-count="4" verbose="2">

    <test name="all-tests">
        <groups>
            <run>
                <include name="arithmetic"/>
                <include name="scientific"/>
                <include name="trigonometric"/>
                <include name="boolean"/>
            </run>
        </groups>
        <classes>
            <class name="test.calculator.SumLongTest"/>
            <class name="test.calculator.SumDoubleTest"/>
            <class name="test.calculator.SubLongTest"/>
            <class name="test.calculator.SubDoubleTest"/>
            <class name="test.calculator.MultLongTest"/>
            <class name="test.calculator.MultDoubleTest"/>
            <class name="test.calculator.DivLongTest"/>
            <class name="test.calculator.DivDoubleTest"/>
            <class name="test.calculator.PowTest"/>
            <class name="test.calculator.SqrtTest"/>
            <class name="test.calculator.TgTest"/>
            <class name="test.calculator.CtgTest"/>
            <class name="test.calculator.CosTest"/>
            <class name="test.calculator.SinTest"/>
            <class name="test.calculator.IsPositiveTest"/>
            <class name="test.calculator.IsNegativeTest"/>
        </classes>
    </test>

</suite>