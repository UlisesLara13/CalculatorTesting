<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="BooleanSuite" parallel="classes" thread-count="2" verbose="2">

    <test name="BooleanTests">
        <groups>
            <run>
                <include name="boolean"/>
            </run>
        </groups>
        <classes>
            <class name="test.calculator.IsPositiveTest"/>
            <class name="test.calculator.IsNegativeTest"/>
        </classes>
    </test>

</suite>