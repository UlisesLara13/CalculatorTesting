<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="ScientificSuite" parallel="classes" thread-count="2" verbose="2">

    <test name="ScientificTests">
        <groups>
            <run>
                <include name="scientific"/>
            </run>
        </groups>
        <classes>
            <class name="test.calculator.PowTest"/>
            <class name="test.calculator.SqrtTest"/>
        </classes>
    </test>

</suite>